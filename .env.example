# Backend configuration example
# Copy to .env and fill with your values

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database (PostgreSQL example)
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+psycopg://dbuser:dbpassword@localhost:5432/dbname

# Security
# Use a long random string; don't share this publicly
JWT_SECRET_KEY=change-me-to-a-long-random-string

# LangChain / LangSmith
LANGCHAIN_PROJECT=your_project_name
LANGCHAIN_API_KEY=sk-your-langsmith-key
